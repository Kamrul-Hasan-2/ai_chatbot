# Google API Configuration (for Gemini AI model)
GOOGLE_API_KEY=your_google_api_key_here

# Facebook Messenger Configuration
PAGE_ACCESS_TOKEN=your_facebook_page_access_token
VERIFY_TOKEN=my_verify_token_12345

# Server Configuration
PORT=5000
FLASK_ENV=production

# Gunicorn Configuration (optional)
GUNICORN_WORKERS=4  # Number of worker processes

# Model Configuration (optional - uses defaults if not set)
MODEL_NAME=Qwen/Qwen2-VL-2B-Instruct
DEVICE=cuda  # or 'cpu'

# Data File Path (optional)
DATA_FILE=data/admin_data.json

# RAG Configuration
ENABLE_RAG=true       # Enable/disable RAG (true/false)
RAG_TOP_K=3           # Number of documents to retrieve (1-10)
