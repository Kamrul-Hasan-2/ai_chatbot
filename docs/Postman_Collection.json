    {
      "name": "Facebook Messenger",
      "item": [
        {
          "name": "Verify Webhook (GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/webhook?hub.mode=subscribe&hub.verify_token=my_verify_token_12345&hub.challenge=test_challenge",
              "host": ["{{base_url}}"],
              "path": ["webhook"],
              "query": [
                {
                  "key": "hub.mode",
                  "value": "subscribe"
                },
                {
                  "key": "hub.verify_token",
                  "value": "my_verify_token_12345"
                },
                {
                  "key": "hub.challenge",
                  "value": "test_challenge"
                }
              ]
            },
            "description": "Verify Facebook webhook (returns challenge)"
          }
        },
        {
          "name": "Webhook Message (POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"page\",\n  \"entry\": [\n    {\n      \"messaging\": [\n        {\n          \"sender\": {\"id\": \"USER_ID\"},\n          \"recipient\": {\"id\": \"PAGE_ID\"},\n          \"timestamp\": 1234567890,\n          \"message\": {\n            \"mid\": \"MESSAGE_ID\",\n            \"text\": \"Hello from Facebook\"\n          }\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook",
              "host": ["{{base_url}}"],
              "path": ["webhook"]
            },
            "description": "Simulate Facebook message webhook"
          }
        }
      ]
    },
